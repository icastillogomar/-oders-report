# Path al archivo JSON de la Service Account.
# Debe estar fuera de cualquier carpeta servida públicamente.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Project ID de GCP donde se ejecutarán los jobs de BigQuery.
GCP_PROJECT_ID=fechaestimadaentregaprod

# Ubicación del dataset (US, EU, us-central1, etc.)
BQ_LOCATION=US

# Puerto del backend (Vite hace proxy aquí)
PORT=3001
